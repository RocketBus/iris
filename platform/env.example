# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- NextAuth (required) ---
# In production set NEXTAUTH_URL to the public canonical URL (e.g. https://iris.example.com).
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_DEBUG=true

# --- JWT for microservices (optional, falls back to NEXTAUTH_SECRET) ---
JWT_SECRET=your-jwt-secret-key-min-32-characters-long
JWT_ISSUER=iris
JWT_AUDIENCE=microservices

# --- GitHub OAuth (recommended primary login) ---
# Create at https://github.com/settings/developers
# Authorization callback URL: ${NEXTAUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- App ---
NEXT_PUBLIC_APP_NAME=Iris
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOGO_URL=/logo.svg

# --- Feature flags ---
# Override defaults from config/features.config.ts. Use FEATURES__<NAME>=true
# server-side, NEXT_PUBLIC_FEATURES__<NAME>=true if a client component needs to
# read it directly. The signin page and `/api/auth/available-providers` already
# expose passwordAuth at runtime, so the server-side override is sufficient.
#
# passwordAuth — email + password signup, login, recovery, email-based 2FA.
# Off by default. Turn on if your deployment needs manual login alongside OAuth.
# FEATURES__PASSWORD_AUTH=false

# --- Resend (required for transactional emails) ---
# Get an API key at https://resend.com/api-keys
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@example.com

# --- Security contact (used in SECURITY.md / Code of Conduct surfaces) ---
SECURITY_CONTACT_EMAIL=security@example.com

# --- Deployment operator (drives Privacy Policy + Terms of Service) ---
# Set these to identify the legal entity operating THIS deployment.
# That entity is the LGPD/GDPR data Controller and the counterparty to the Terms.
# Forks / self-hosters set their own values. Leaving them empty renders
# placeholder text in the public Privacy / Terms pages.
#
# Examples:
#   NEXT_PUBLIC_OPERATOR_NAME=Acme Inc.
#   NEXT_PUBLIC_OPERATOR_JURISDICTION=São Paulo, Brazil
#   NEXT_PUBLIC_OPERATOR_PRIVACY_EMAIL=privacy@acme.example
#   NEXT_PUBLIC_OPERATOR_DPO_EMAIL=privacy@acme.example
NEXT_PUBLIC_OPERATOR_NAME=
NEXT_PUBLIC_OPERATOR_JURISDICTION=
NEXT_PUBLIC_OPERATOR_PRIVACY_EMAIL=
NEXT_PUBLIC_OPERATOR_DPO_EMAIL=

# --- Debug ---
DEBUG_LEVEL=DEBUG
DEBUG_AUTH=true
DEBUG_EMAIL=true
DEBUG_DATABASE=true
DEBUG_API=true

# --- Feature flags ---
FEATURES__AUDIT_LOG=false
NEXT_PUBLIC_FEATURES__AUDIT_LOG=false
